{
  "type": "div",
  "class": "page-root",
  "style": {
    "backgroundColor": "#000000",
    "height": "100%",
    "width": "100%"
  },
  "styleObjectId": 1806868334,
  "children": [
    {
      "type": "div",
      "class": "page-shell",
      "style": {
        "alignItems": "center",
        "backgroundColor": "#000000",
        "flexDirection": "column",
        "height": "100%",
        "width": "100%"
      },
      "children": [
        {
          "type": "text",
          "attr": {
            "$value": "todayText"
          },
          "bind": 1,
          "class": "page-date",
          "style": {
            "color": "#9fb0c1",
            "fontSize": "24px",
            "marginBottom": "20px",
            "marginTop": "24px",
            "textAlign": "center"
          }
        },
        {
          "type": "scroll",
          "attr": {
            "scrollX": "true"
          },
          "class": "card-scroll",
          "style": {
            "height": "320px",
            "width": "100%"
          },
          "children": [
            {
              "type": "div",
              "class": "card-row",
              "style": {
                "alignItems": "center",
                "flexDirection": "row",
                "height": "320px",
                "paddingLeft": "18px",
                "paddingRight": "18px"
              },
              "children": [
                {
                  "type": "div",
                  "bind": 2,
                  "class": "progress-card",
                  "repeat": {
                    "$exp": "cards",
                    "key": "index",
                    "value": "item"
                  },
                  "children": [
                    {
                      "type": "div",
                      "class": "ring-wrap",
                      "children": [
                        {
                          "type": "svg",
                          "attr": {
                            "viewBox": "0 0 120 120"
                          },
                          "class": "ring-svg",
                          "children": [
                            {
                              "type": "circle",
                              "attr": {
                                "cx": "60",
                                "cy": "60",
                                "r": "48"
                              },
                              "class": "ring-track"
                            },
                            {
                              "type": "circle",
                              "attr": {
                                "$stroke": "item.color",
                                "$strokeDasharray": "item.circumference",
                                "$strokeDashoffset": "item.dashOffset",
                                "cx": "60",
                                "cy": "60",
                                "r": "48"
                              },
                              "bind": 1,
                              "class": "ring-progress"
                            }
                          ]
                        },
                        {
                          "type": "div",
                          "class": "ring-center",
                          "children": [
                            {
                              "type": "text",
                              "attr": {
                                "$value": "item.percent"
                              },
                              "bind": 1,
                              "class": "ring-percent"
                            },
                            {
                              "type": "text",
                              "attr": {
                                "$value": "item.title"
                              },
                              "bind": 1,
                              "class": "ring-title"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "attr": {
                        "$value": "item.detail"
                      },
                      "bind": 1,
                      "class": "card-detail"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}