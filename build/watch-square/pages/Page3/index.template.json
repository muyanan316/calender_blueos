{
  "type": "scroll",
  "class": "page-scroll",
  "style": {
    "backgroundColor": "#000000",
    "height": "100%",
    "width": "100%"
  },
  "styleObjectId": 1217327819,
  "children": [
    {
      "type": "div",
      "class": "page-shell",
      "style": {
        "alignItems": "center",
        "backgroundColor": "#000000",
        "flexDirection": "column",
        "minHeight": "100%",
        "paddingBottom": "32px",
        "paddingTop": "28px",
        "width": "100%"
      },
      "children": [
        {
          "type": "text",
          "attr": {
            "value": "Solar Terms"
          },
          "class": "page-title",
          "style": {
            "color": "#ffffff",
            "fontSize": "36px",
            "textAlign": "center"
          }
        },
        {
          "type": "text",
          "attr": {
            "$value": "todayText"
          },
          "bind": 1,
          "class": "page-date",
          "style": {
            "color": "#8fa1b3",
            "fontSize": "22px",
            "marginTop": "10px",
            "textAlign": "center"
          }
        },
        {
          "type": "div",
          "class": "hero-card",
          "style": {
            "alignItems": "center",
            "backgroundColor": "#132016",
            "borderRadius": "28px",
            "flexDirection": "column",
            "marginTop": "24px",
            "paddingBottom": "28px",
            "paddingLeft": "22px",
            "paddingRight": "22px",
            "paddingTop": "28px",
            "width": "410px"
          },
          "children": [
            {
              "type": "text",
              "attr": {
                "value": "最近节气"
              },
              "class": "hero-caption",
              "style": {
                "color": "#9ec6a3",
                "fontSize": "20px",
                "textAlign": "center"
              }
            },
            {
              "type": "text",
              "attr": {
                "$value": "seasonTitle"
              },
              "bind": 1,
              "class": "hero-title",
              "style": {
                "color": "#ffffff",
                "fontSize": "40px",
                "marginTop": "10px",
                "textAlign": "center"
              }
            },
            {
              "type": "text",
              "attr": {
                "$value": "seasonDateText"
              },
              "bind": 1,
              "class": "hero-date",
              "style": {
                "color": "#d9f4dc",
                "fontSize": "24px",
                "marginTop": "8px",
                "textAlign": "center"
              }
            },
            {
              "type": "text",
              "attr": {
                "$value": "seasonHint"
              },
              "bind": 1,
              "class": "hero-hint",
              "style": {
                "color": "#c2ddc6",
                "fontSize": "22px",
                "lines": 3,
                "marginTop": "14px",
                "textAlign": "center",
                "width": "330px"
              }
            },
            {
              "type": "text",
              "attr": {
                "$value": "seasonDistanceText"
              },
              "bind": 1,
              "class": "hero-distance",
              "style": {
                "color": "#7fd38b",
                "fontSize": "22px",
                "marginTop": "16px",
                "textAlign": "center"
              }
            }
          ]
        },
        {
          "type": "div",
          "class": "timeline-card",
          "style": {
            "backgroundColor": "#0d1520",
            "borderRadius": "28px",
            "flexDirection": "column",
            "marginTop": "18px",
            "paddingBottom": "20px",
            "paddingLeft": "20px",
            "paddingRight": "20px",
            "paddingTop": "22px",
            "width": "410px"
          },
          "children": [
            {
              "type": "text",
              "attr": {
                "value": "二十四节气"
              },
              "class": "section-title",
              "style": {
                "color": "#ffffff",
                "fontSize": "28px",
                "marginBottom": "8px"
              }
            },
            {
              "type": "div",
              "$class": "item.cardClass",
              "bind": 2,
              "repeat": {
                "$exp": "termCards",
                "key": "index",
                "value": "item"
              },
              "children": [
                {
                  "type": "div",
                  "class": "term-head",
                  "children": [
                    {
                      "type": "text",
                      "$class": "item.nameClass",
                      "attr": {
                        "$value": "item.name"
                      },
                      "bind": 1
                    },
                    {
                      "type": "text",
                      "attr": {
                        "$value": "item.dateText"
                      },
                      "bind": 1,
                      "class": "term-date"
                    }
                  ]
                },
                {
                  "type": "text",
                  "attr": {
                    "$value": "item.hint"
                  },
                  "bind": 1,
                  "class": "term-hint"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}