{
  "type": "scroll",
  "class": "page-scroll",
  "style": {
    "backgroundColor": "#000000",
    "height": "100%",
    "width": "100%"
  },
  "styleObjectId": 1020814314,
  "children": [
    {
      "type": "div",
      "class": "page-shell",
      "style": {
        "alignItems": "center",
        "backgroundColor": "#000000",
        "flexDirection": "column",
        "minHeight": "100%",
        "paddingBottom": "32px",
        "paddingTop": "28px",
        "width": "100%"
      },
      "children": [
        {
          "type": "text",
          "attr": {
            "value": "Moon Phase"
          },
          "class": "page-title",
          "style": {
            "color": "#ffffff",
            "fontSize": "36px",
            "textAlign": "center"
          }
        },
        {
          "type": "text",
          "attr": {
            "$value": "todayText"
          },
          "bind": 1,
          "class": "page-date",
          "style": {
            "color": "#8fa1b3",
            "fontSize": "22px",
            "marginTop": "10px",
            "textAlign": "center"
          }
        },
        {
          "type": "div",
          "class": "hero-card",
          "style": {
            "alignItems": "center",
            "backgroundColor": "#0d1520",
            "borderRadius": "28px",
            "flexDirection": "column",
            "marginTop": "24px",
            "paddingBottom": "28px",
            "paddingLeft": "20px",
            "paddingRight": "20px",
            "paddingTop": "28px",
            "width": "410px"
          },
          "children": [
            {
              "type": "div",
              "class": "moon-stage",
              "style": {
                "alignItems": "center",
                "backgroundColor": "#04070b",
                "borderRadius": "95px",
                "height": "190px",
                "justifyContent": "center",
                "position": "relative",
                "width": "190px"
              },
              "children": [
                {
                  "type": "div",
                  "class": "moon-base",
                  "style": {
                    "backgroundColor": "#f3f4f6",
                    "borderRadius": "74px",
                    "height": "148px",
                    "width": "148px"
                  }
                },
                {
                  "type": "div",
                  "$shown": "function () { return this.phaseKey === 'new'; }",
                  "bind": 2,
                  "class": "moon-mask moon-mask-new",
                  "shown": false
                },
                {
                  "type": "div",
                  "$shown": "function () { return this.phaseKey === 'waxing-crescent'; }",
                  "bind": 2,
                  "class": "moon-mask moon-mask-waxing-crescent",
                  "shown": false
                },
                {
                  "type": "div",
                  "$shown": "function () { return this.phaseKey === 'first-quarter'; }",
                  "bind": 2,
                  "class": "moon-mask moon-mask-first-quarter",
                  "shown": false
                },
                {
                  "type": "div",
                  "$shown": "function () { return this.phaseKey === 'waxing-gibbous'; }",
                  "bind": 2,
                  "class": "moon-mask moon-mask-waxing-gibbous",
                  "shown": false
                },
                {
                  "type": "div",
                  "$shown": "function () { return this.phaseKey === 'full'; }",
                  "bind": 2,
                  "class": "moon-glow",
                  "shown": false
                },
                {
                  "type": "div",
                  "$shown": "function () { return this.phaseKey === 'waning-gibbous'; }",
                  "bind": 2,
                  "class": "moon-mask moon-mask-waning-gibbous",
                  "shown": false
                },
                {
                  "type": "div",
                  "$shown": "function () { return this.phaseKey === 'last-quarter'; }",
                  "bind": 2,
                  "class": "moon-mask moon-mask-last-quarter",
                  "shown": false
                },
                {
                  "type": "div",
                  "$shown": "function () { return this.phaseKey === 'waning-crescent'; }",
                  "bind": 2,
                  "class": "moon-mask moon-mask-waning-crescent",
                  "shown": false
                }
              ]
            },
            {
              "type": "text",
              "attr": {
                "$value": "phaseName"
              },
              "bind": 1,
              "class": "phase-name",
              "style": {
                "color": "#ffffff",
                "fontSize": "34px",
                "marginTop": "24px",
                "textAlign": "center"
              }
            },
            {
              "type": "text",
              "attr": {
                "$value": "phaseDesc"
              },
              "bind": 1,
              "class": "phase-desc",
              "style": {
                "color": "#a3b4c5",
                "fontSize": "22px",
                "lines": 3,
                "marginTop": "12px",
                "textAlign": "center",
                "width": "330px"
              }
            }
          ]
        },
        {
          "type": "div",
          "class": "info-grid",
          "style": {
            "flexDirection": "row",
            "flexWrap": "wrap",
            "justifyContent": "space-between",
