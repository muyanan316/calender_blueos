                    "$value": "moonAgeText"
                  },
                  "bind": 1,
                  "class": "info-value",
                  "style": {
                    "color": "#ffffff",
                    "fontSize": "24px",
                    "marginTop": "10px"
                  }
                }
              ]
            },
            {
              "type": "div",
              "class": "info-card",
              "style": {
                "backgroundColor": "#101b28",
                "borderRadius": "22px",
                "flexDirection": "column",
                "marginBottom": "14px",
                "paddingBottom": "18px",
                "paddingLeft": "18px",
                "paddingRight": "18px",
                "paddingTop": "18px",
                "width": "198px"
              },
              "children": [
                {
                  "type": "text",
                  "attr": {
                    "value": "明暗"
                  },
                  "class": "info-label",
                  "style": {
                    "color": "#72859a",
                    "fontSize": "18px"
                  }
                },
                {
                  "type": "text",
                  "attr": {
                    "$value": "illuminationText"
                  },
                  "bind": 1,
                  "class": "info-value",
                  "style": {
                    "color": "#ffffff",
                    "fontSize": "24px",
                    "marginTop": "10px"
                  }
                }
              ]
            },
            {
              "type": "div",
              "class": "info-card info-card-wide",
              "style": {
                "backgroundColor": "#101b28",
                "borderRadius": "22px",
                "flexDirection": "column",
                "marginBottom": "14px",
                "paddingBottom": "18px",
                "paddingLeft": "18px",
                "paddingRight": "18px",
                "paddingTop": "18px",
                "width": "410px"
              },
              "children": [
                {
                  "type": "text",
                  "attr": {
                    "value": "周期"
                  },
                  "class": "info-label",
                  "style": {
                    "color": "#72859a",
                    "fontSize": "18px"
                  }
                },
                {
                  "type": "text",
                  "attr": {
                    "$value": "cycleText"
                  },
                  "bind": 1,
                  "class": "info-value",
                  "style": {
                    "color": "#ffffff",
                    "fontSize": "24px",
                    "marginTop": "10px"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "div",
          "class": "timeline-card",
          "style": {
            "backgroundColor": "#0d1520",
            "borderRadius": "28px",
            "flexDirection": "column",
            "marginTop": "4px",
            "paddingBottom": "20px",
            "paddingLeft": "20px",
            "paddingRight": "20px",
            "paddingTop": "22px",
            "width": "410px"
          },
          "children": [
            {
              "type": "text",
              "attr": {
                "value": "月相阶段"
              },
              "class": "section-title",
              "style": {
                "color": "#ffffff",
                "fontSize": "28px",
                "marginBottom": "12px"
              }
            },
            {
              "type": "div",
              "bind": 2,
              "class": "phase-step",
              "repeat": {
                "$exp": "phaseSteps",
                "key": "index",
                "value": "item"
              },
              "children": [
                {
                  "type": "div",
                  "$class": "item.dotClass",
                  "bind": 1,
                  "children": [
                    {
                      "type": "text",
                      "attr": {
                        "$value": "item.short"
                      },
                      "bind": 1,
                      "class": "phase-dot-text"
                    }
                  ]
                },
                {
                  "type": "div",
                  "class": "phase-meta",
                  "children": [
                    {
                      "type": "text",
                      "$class": "item.nameClass",
                      "attr": {
                        "$value": "item.name"
                      },
                      "bind": 1
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}