{
  "type": "scroll",
  "class": "page-scroll",
  "style": {
    "backgroundColor": "#000000",
    "height": "100%",
    "width": "100%"
  },
  "styleObjectId": 2095071952,
  "children": [
    {
      "type": "div",
      "class": "page-shell",
      "style": {
        "alignItems": "center",
        "backgroundColor": "#000000",
        "flexDirection": "column",
        "minHeight": "100%",
        "paddingBottom": "32px",
        "paddingTop": "28px",
        "width": "100%"
      },
      "children": [
        {
          "type": "text",
          "attr": {
            "$value": "titleText"
          },
          "bind": 1,
          "class": "page-title",
          "style": {
            "color": "#ffffff",
            "fontSize": "36px",
            "textAlign": "center"
          }
        },
        {
          "type": "text",
          "attr": {
            "$value": "subtitleText"
          },
          "bind": 1,
          "class": "page-subtitle",
          "style": {
            "color": "#8fb3c9",
            "fontSize": "22px",
            "marginTop": "8px",
            "textAlign": "center"
          }
        },
        {
          "type": "text",
          "attr": {
            "$value": "todayText"
          },
          "bind": 1,
          "class": "page-date",
          "style": {
            "color": "#7c8c9b",
            "fontSize": "18px",
            "marginTop": "8px",
            "textAlign": "center"
          }
        },
        {
          "type": "div",
          "class": "status-card",
          "style": {
            "alignItems": "center",
            "backgroundColor": "#141c25",
            "borderRadius": "28px",
            "flexDirection": "column",
            "marginTop": "22px",
            "paddingBottom": "22px",
            "paddingLeft": "20px",
            "paddingRight": "20px",
            "paddingTop": "22px",
            "width": "410px"
          },
          "children": [
            {
              "type": "text",
              "attr": {
                "$value": "function () { return '' + this.selectedYear + '年'; }"
              },
              "bind": 1,
              "class": "status-year",
              "style": {
                "color": "#ffd66b",
                "fontSize": "34px",
                "textAlign": "center"
              }
            },
            {
              "type": "text",
              "attr": {
                "$value": "statusText"
              },
              "bind": 1,
              "class": "status-text",
              "style": {
                "color": "#ffffff",
                "fontSize": "24px",
                "lines": 2,
                "marginTop": "10px",
                "textAlign": "center",
                "width": "300px"
              }
            },
            {
              "type": "text",
              "attr": {
                "$value": "sourceText"
              },
              "bind": 1,
              "class": "status-source",
              "style": {
                "color": "#738495",
                "fontSize": "16px",
                "marginTop": "12px",
                "textAlign": "center"
              }
            }
          ]
        },
        {
          "type": "div",
          "$shown": "function () { return this.yearButtons.length > 1; }",
          "bind": 2,
          "class": "year-row",
          "shown": false,
          "children": [
            {
              "type": "div",
              "$class": "item.buttonClass",
              "attr": {
                "$dataYear": "item.year"
              },
              "bind": 2,
              "events": {
                "click": "chooseYear"
              },
              "repeat": {
                "$exp": "yearButtons",
                "key": "index",
                "value": "item"
              },
              "children": [
                {
                  "type": "text",
                  "$class": "item.textClass",
                  "attr": {
                    "$value": "item.year"
                  },
                  "bind": 1
                }
              ]
            }
          ]
        },
        {
          "type": "div",
          "class": "section-card",
          "style": {
            "backgroundColor": "#0d1520",
            "borderRadius": "28px",
            "flexDirection": "column",
            "marginTop": "18px",
            "paddingBottom": "20px",
            "paddingLeft": "20px",
            "paddingRight": "20px",
            "paddingTop": "22px",
            "width": "410px"
          },
          "children": [
            {
              "type": "text",
              "attr": {
                "value": "放假安排"
              },
              "class": "section-title",
              "style": {
                "color": "#ffffff",
                "fontSize": "28px",
                "marginBottom": "8px"
              }
            },
            {
              "type": "div",
              "bind": 2,
              "class": "holiday-card",
              "repeat": {
                "$exp": "holidayCards",
                "key": "index",
                "value": "item"
              },
              "children": [
                {
                  "type": "div",
                  "class": "holiday-head",
                  "children": [
                    {
                      "type": "text",
                      "attr": {
                        "$value": "item.name"
                      },
                      "bind": 1,
                      "class": "holiday-name"
                    },
                    {
                      "type": "text",
                      "attr": {
                        "$value": "item.daysText"
                      },
                      "bind": 1,
                      "class": "holiday-days"
                    }
                  ]
                },
                {
                  "type": "text",
                  "attr": {
                    "$value": "item.range"
                  },
                  "bind": 1,
                  "class": "holiday-range"
                }
              ]
            },
            {
              "type": "text",
              "$shown": "function () { return this.holidayCards.length === 0; }",
              "attr": {
                "value": "后续没有待显示的放假安排"
              },
              "bind": 2,
              "class": "empty-text",
              "shown": true
            }
          ]
        },
        {
          "type": "div",
          "class": "section-card",
          "style": {
            "backgroundColor": "#0d1520",
            "borderRadius": "28px",
            "flexDirection": "column",
            "marginTop": "18px",
            "paddingBottom": "20px",
            "paddingLeft": "20px",
            "paddingRight": "20px",
            "paddingTop": "22px",
            "width": "410px"
          },
          "children": [
            {
              "type": "text",
              "attr": {
                "value": "调休上班"
              },
              "class": "section-title",
              "style": {
                "color": "#ffffff",
                "fontSize": "28px",
                "marginBottom": "8px"
              }
            },
            {
              "type": "div",
              "bind": 2,
              "class": "workday-chip",
              "repeat": {
                "$exp": "workdayCards",
                "key": "index",
                "value": "item"
              },
              "children": [
                {
                  "type": "text",
                  "attr": {
                    "$value": "item.text"
                  },
                  "bind": 1,
                  "class": "workday-text"
                }
              ]
            },
            {
              "type": "text",
              "$shown": "function () { return this.workdayCards.length === 0; }",
              "attr": {
                "value": "后续没有待显示的调休上班日"
              },
              "bind": 2,
              "class": "empty-text",
              "shown": true
            }
          ]
        }
      ]
    }
  ]
}